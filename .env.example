# ══════════════════════════════════════════════
# Research Synthesizer — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════

# ── LLM Backend ──
# Options: "groq" (cloud, free, recommended) or "ollama" (local)
LLM_BACKEND=groq

# ── Groq (Free Cloud LLM) ──
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.3

# ── Ollama (Local LLM – optional fallback) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0.3

# ── Embeddings ──
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── ArXiv ──
ARXIV_MAX_RESULTS=5
ARXIV_RATE_LIMIT=3.0
ARXIV_NUM_RETRIES=3

# ── Plagiarism / Semantic Overlap ──
SEMANTIC_OVERLAP_THRESHOLD=0.70
MAX_REWRITE_ATTEMPTS=3

# ── Report ──
TARGET_REPORT_WORDS=1500

# ── Logging ──
LOG_LEVEL=INFO
VERBOSE=true
