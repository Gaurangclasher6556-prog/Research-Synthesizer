# Research Synthesizer - Environment Variables
# Copy this file to .env and fill in your values
# Add MULTIPLE provider keys for automatic failover!

# -- LLM Backend --
LLM_BACKEND=groq

# -- Google Gemini (Primary - 1500 RPD free) --
# Get free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.3

# -- Groq (Fallback 1 - fast inference) --
# Get free key: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.3

# -- OpenRouter (Fallback 2 - many free models) --
# Get free key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-lite-preview-02-05:free

# -- Ollama (Local fallback - no key needed) --
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0.3

# -- Embeddings --
EMBEDDING_MODEL=all-MiniLM-L6-v2

# -- ArXiv --
ARXIV_MAX_RESULTS=5
ARXIV_RATE_LIMIT=3.0
ARXIV_NUM_RETRIES=3

# -- Plagiarism / Semantic Overlap --
SEMANTIC_OVERLAP_THRESHOLD=0.70
MAX_REWRITE_ATTEMPTS=3

# -- Report --
TARGET_REPORT_WORDS=1500

# -- Logging --
LOG_LEVEL=INFO
VERBOSE=true
